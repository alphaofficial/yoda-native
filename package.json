{
  "name": "yoda-native",
  "version": "0.1.0",
  "description": "Dev dashboard",
  "main": "dist/desktop/main.js",
  "scripts": {
    "build": "npm run build:client && npm run build:ssr && npm run build:server",
    "build:client": "vite build",
    "build:desktop": "node scripts/build-desktop.mjs",
    "build:server": "rimraf dist/events dist/jobs dist/scheduler && tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "build:ssr": "vite build --config vite.ssr.config.mjs",
    "db:seed": "mikro-orm seeder:run",
    "desktop:dev": "npm run build && npm run build:desktop && unset ELECTRON_RUN_AS_NODE; electron .",
    "desktop:package": "npm run build && npm run build:desktop && electron-builder --config scripts/electron-builder.config.cjs",
    "desktop:signing:check": "node scripts/check-desktop-signing.mjs",
    "desktop:start": "unset ELECTRON_RUN_AS_NODE; electron .",
    "migrate": "npm run migration:create && npm run migration:run",
    "migration:create": "mikro-orm migration:create",
    "migration:revert": "mikro-orm migration:down",
    "migration:run": "mikro-orm migration:up",
    "migration:status": "mikro-orm migration:check",
    "pages:generate": "tsx scripts/generate-pages.ts",
    "pages:watch": "chokidar \"src/views/pages/**/*.tsx\" -c \"npm run pages:generate\" --initial",
    "prebuild": "npm run pages:generate",
    "prestart:dev": "npm run pages:generate && npm run build:ssr",
    "prestart:prod": "npm run build",
    "prework:prod": "npm run build:server",
    "start:dev": "concurrently --names \"pages,server,client,ssr\" --prefix-colors \"yellow,cyan,magenta,blue\" \"npm run pages:watch\" \"npm run start:dev:server\" \"npm run start:dev:client\" \"npm run start:dev:ssr\"",
    "start:dev:client": "vite build --watch",
    "start:dev:server": "nodemon",
    "start:dev:ssr": "vite build --config vite.ssr.config.mjs --watch",
    "start:prod": "node dist/index.js",
    "test:typecheck": "tsc --pretty false -p tsconfig.tests.json",
    "work:dev": "tsx src/worker.ts",
    "work:prod": "node dist/worker.js",
    "dashboard:setup": "tsx scripts/setup-dashboard-db.ts",
    "start:docker": "docker compose up -d --build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test:typecheck && npm test && npm run test:e2e"
  },
  "keywords": [],
  "author": "Albert Akrong <alphaxsalt@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@inertiajs/react": "^2.1.11",
    "@mikro-orm/core": "^6.5.8",
    "@mikro-orm/migrations": "^6.5.1",
    "@mikro-orm/postgresql": "^6.5.1",
    "@mikro-orm/seeder": "^6.6.16",
    "@mikro-orm/sqlite": "^6.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express-session": "^1.18.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "better-queue": "^3.8.12",
    "compression": "^1.8.1",
    "dotenv-defaults": "^5.0.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^8.0.5",
    "pg-connection-string": "^2.9.1",
    "pino-http": "^10.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.2",
    "@base-ui/react": "^1.6.0",
    "@primer/octicons-react": "^19.29.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.5.1",
    "@playwright/test": "^1.59.1",
    "@types/better-queue": "^3.8.6",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.31",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "vite": "^6.4.0",
    "vitest": "^4.1.7",
    "wait-on": "^9.1.0"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/database/orm.config.ts",
      "./dist/database/orm.config.js"
    ]
  },
  "build": {
    "appId": "com.alphaofficial.yoda.native",
    "productName": "Yoda",
    "asar": false,
    "files": [
      "dist/**/*",
      "!dist/*.dmg",
      "!dist/*.zip",
      "!dist/*.blockmap",
      "!dist/mac*/**/*",
      "public/**/*",
      "config/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@mikro-orm/sqlite/**/*",
      "node_modules/bcrypt/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    }
  },
  "tbd": {
    "version": "main",
    "kind": "branch"
  }
}
