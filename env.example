# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# Required in production. Used for HMAC token signing. Generate with: openssl rand -hex 32
APP_KEY=your_app_key_here

# App
NODE_ENV=development
PORT=3000
APP_NAME=The Boring Architecture
APP_URL=http://localhost:3000

# Trust proxy: 'loopback', 'true', a number of hops, or an IP/CIDR list.
# Set to 'true' (or your LB CIDR) when running behind a reverse proxy.
TRUST_PROXY=loopback

# Session
SESSION_MAX_AGE=86400000

# Database
DB_PATH=yoda.db
BACKUP_PATH=backups

# Rate limiting (off by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_FEATURE_MAX=60
RATE_LIMIT_FEATURE_WINDOW_MS=60000

# Password reset expiry in minutes (default 60)
PASSWORD_RESET_EXPIRY=60

# Email verification expiry in minutes (default 60)
EMAIL_VERIFICATION_EXPIRY=60

# Mailer
MAIL_FROM=noreply@example.com
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=smtp_user
# MAIL_PASS=smtp_password

# File Storage
STORAGE_PATH=storage

# SSR is enabled by default. Set to true to ship a client-only shell.
DISABLE_SSR=false

# Dashboard
DASHBOARD_CONFIG_PATH=config/dashboard.json
DASHBOARD_CACHE_TTL_SECONDS=900
GITHUB_REPOSITORY_CACHE_TTL_SECONDS=86400
DASHBOARD_REQUEST_TIMEOUT_MS=5000
DASHBOARD_RETRY_COUNT=2

# GitHub Integration
# GITHUB_TOKEN=your_github_token_here

# Google Calendar Integration
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REFRESH_TOKEN=your_google_refresh_token
